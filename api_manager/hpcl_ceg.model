Enum BusinessUnit str {
    RO='RO'
    TAS='TAS'
    LPG='LPG'
    RDI='RDI'
    CP='CP'
    CDCMS='CDCMS'
    ALL='ALL'
    DS='DS'
}

Enum VtsLive str {
    TripOngoing = 'Live'
    TripCompleted = 'Closed'
}

Enum BlockStatus str {
    Blocked='Blocked'
    UnBlocked='UnBlocked'
    WaitingForBlockAck='WaitingForBlockAck'
    WaitingForUnBlockAck='WaitingForUnBlockAck'
    OnGoingTrip='OnGoingTrip'
}

Enum DeviceType str {
    Tank='Tank'
    DU='DU'
    Pump='Pump'
    Nozzle='Nozzle'
    ATG='ATG'
}

Enum LoginStatus str {
    login='Logged In'
    logout='Logged Out'
}

Enum MakerChecker str {
    MAKER='maker'
    CHECKER='checker'
}

Enum NotificationLevel str {
    InitialNotification='InitialNotification'
    InitialEscalation='InitialEscalation'
}

Enum AlertStatus str {
    Open='Open'
    Close='Close'
    InProgress='InProgress'
    Cancel='Cancel'
    OnHold='OnHold'
    Resolved='Resolved'
}

Enum AlertState str {
    InProgress='InProgress'
    Notified='Notified'
    Escalated='Escalated'
    Resolved='Resolved'
}

Enum Severity str {
    Low='Low'
    Medium='Medium'
    High='High'
    Critical='Critical'
}

Enum LocationHealth str {
    Normal='Normal'
    Failed='Failed'
    Deactivated='Deactivated'
}

Enum AlertActionType str {
    Justification='Justification'
    AcceptClose='AcceptClose'
    FalseAlert='FalseAlert'
    InvalidAlert='InvalidAlert'
    ValidAlert='ValidAlert'
    Rejected='Rejected'
    Approved='Approved'
    Override='Override'
    interLockOk='interLockOk'
    Message='Message'
    excApprovalTimeExp='excApprovalTimeExp'
    Raised='Raised'
    Cancelled='Cancelled'
    Allocated='Allocated'
    SentToSap='SentToSap'
    OrderPlaced='OrderPlaced'
    Created='Created'
    R1Swipe='R1Swipe'
    R2Swipe='R2Swipe'
    R3Swipe='R3Swipe'
    VTS='VTS'
    Delivered='Delivered'
    Tripped='Tripped'
    InterlockCreated='InterlockCreated'
    InterlockCleared='InterlockCleared'
    InterlockNotCleared='InterlockNotCleared'
    UnderMaintenance='UnderMaintenance'
    RevocationApproved='RevocationApproved'
    ExceptionApproved='ExceptionApproved'
    Active='Active'
    Notified='Notified'
    Escalated='Escalated'
    Resolved='Resolved'
    Blocked='Blocked'
    UnBlocked='UnBlocked'
    Request='Request'
    Interrupt='Interrupt'
    BayReAssigned='BayReAssigned'
    Effect='Effect'
    Cause='Cause'
    ESDFailure='ESDFailure'
    Maintenance='Maintenance'
    TicketRaised='TicketRaised'
    TicketInProgress='TicketInProgress'
    TicketCancelled='TicketCancelled'
    TicketResolved='TicketResolved'
    TicketOnHold='TicketOnHold'
    TicketReOpen='TicketReOpen'
    TicketOnCompleted='TicketOnCompleted'
    SendItBack='SendItBack'
    FalseViolation='FalseViolation'
    AcceptViolation='AcceptViolation'
    BlockFailed='BlockFailed'
    UnblockFailed='UnblockFailed'
    OngoingTrip='OngoingTrip'
    BlockInitiated='BlockInitiated'
    UnBlockInitiated='UnBlockInitiated'
    OccBlockingRemarks='OccBlockingRemarks'
    OccUnblockingRemarks='OccUnblockingRemarks'
    Remarks='Remarks'
    Offline='Offline'
}

Enum IndentStatus str {
    Pending='Pending'
    IndentNotRaised='IndentNotRaised'
    IndentRaised='IndentRaised'
    IndentOnHold='IndentOnHold'
    IndentOnHoldReleased='IndentOnHoldReleased'
    Cancelled='Cancelled'
    TruckAllocated='TruckAllocated'
    TruckNotAllocated='TruckNotAllocated'
    Transit='Transit'
    InvoiceCreated='InvoiceCreated'
    ValidIndent='ValidIndent'
    SentToSAP='SentToSAP'
    SalesOrderPlaced='SalesOrderPlaced'
    Completed='Completed'
    R1Swipe='R1Swipe'
    R2Swipe='R2Swipe'
    R3Swipe='R3Swipe'
    VTS='VTS'
    Delivered='Delivered'
    TempClosed='TempClosed'
    ProductLowLevel='ProductLowLevel'
    OfflineOrFalseAlarm='OfflineOrFalseAlarm'
    NotAvailable='NotAvailable'
}

Enum AlertActionState str {
    CreatedAt='CreatedAt'
    ClosedAt='ClosedAt'

    // FOR VTS and RO
    BlockInitiated='BlockInitiated'
    UnBlockInitiated='UnBlockInitiated'
    Blocked='Blocked'
    UnBlocked='Unblocked'
    BlockAck='BlockAck'
    UnblockAck='UnblockAck'

    // FOR SupplyChain / DryOut

}

Model RoleMapper internal {
     menu_name str
     allowed_sub_menus optional list str
}

// System role master with allowed pages
Model Roles {
    name index_field unique_field str
    status bool
    allowed_pages optional list RoleMapper

    // API to create system role
    Action=> create_role {
        name str
        allowed_pages optional list RoleMapper
    }

    // API to Enable/Disable system role
    Action=> update_role_status {
        enable bool
        role_name str
    }

    // API to fetch list of pages available for configuring role
    Action=> get_all_pages {

    }

    Config=> {
        crud_operations='read'
    }
}

Model UserLoginAudit {
    employee_id index_field str
    email index_field str
    role str
    login_id index_field str
    login_time optional datetime
    logout_time optional datetime
    login_status optional LoginStatus
    failure_reason optional str
    auth_method str // SSO or Password
    user_agent optional str // request.headers.get("user-agent", "Unknown")
    remarks optional str

    Action=> fetch_login_audit {
        search_string optional str
        limit optional default=100 int
        skip optional default=0 int
    }

}

Model Users {
    // User Information
    username index_field unique_field str
    email index_field str
    first_name str
    last_name str
    password optional secret
    employee_id index_field unique_field str
    employee_number optional str
    // Allocated Role
    // ALL for all
    bu index_field list BusinessUnit
    // ALL for all
    sap_id index_field list str
    system_role index_field list str
    novex_role index_field list str
    region optional list str
    state index_field list str
    zone index_field list str
    sales_area index_field list str
    escalation_level optional NotificationLevel
    // User authentication type
    is_ad_user bool
    status bool
    manual_user bool
    contact_number optional str

    // API to list out created users
    Action=> fetch_users {
        search_string str
        limit optional default=100 int
        skip optional default=0 int
    }

    // API to create user
    Action=> create_user {
        username str
        password str
        first_name str
        last_name str
        employee_id str
        role list str
    }

    // API to Enable/Disable system user
    Action=> update_user_status {
        enable bool
        username str
        first_name str
        last_name str
        region optional list str
        state index_field list str
        zone index_field list str
        sap_id index_field list str
        bu index_field list BusinessUnit
        sales_area index_field list str
        novex_role index_field str
    }

    // API for user login
    Action=> login {
        username str regex="^[a-zA-Z0-9_.-]+$"
        password str
        login_type optional default='employee' str
    }

    

    Action=> applogin {
        username str regex="^[a-zA-Z0-9_.-]+$"
        password str
        login_type optional default='employee' str
    }

    // API for user logout
    Action=> logout {
    }

    Config=> {
        crud_operations='read'
        search_fields='username,email,first_name,last_name,employee_id,employee_number'
    }

}

Model DataFilters internal {
    key str
    cond str
    value str
}

Enum TasLogAction str {
    GantryShutdown='GantryShutdown'
    ESDShutdown='ESDShutdown'
    SignalClearOff='SignalClearOff'
}

Enum TasLogSection str {
    Gantry='Gantry'
    ESD='ESD'
}

Model TasActionLogs {
    username index_field str
    email optional index_field str
    first_name optional str
    last_name optional str
    employee_id optional index_field str
    employee_number optional str
    bu index_field list BusinessUnit
    sap_id index_field list str
    location_name index_field list str
    system_role index_field list str
    novex_role index_field list str
    region optional list str
    state optional list str
    zone optional list str
    sales_area optional list str
    description optional str
    comments optional str
    action optional TasLogAction
    section optional TasLogSection

    Action=> capture_logs {
        sap_id str
        action str
        description optional str
        comments optional str
        section optional str
    }
    Config=> {
        access_key_mapping='bu,zone,region,sales_area,sap_id'
    }
}

Model LocationMaster {
    bu unique_field index_field BusinessUnit
    sap_id unique_field index_field str
    bu_id optional str
    ro_id optional str
    name index_field str
    is_active optional bool
    activation_date optional datetime
    activation_notes optional str
    activated_by optional str
    deactivated_by optional str
    deactivation_notes optional str
