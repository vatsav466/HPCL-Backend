Model IndentDryOutDataFilters internal {
    key str regex="^[a-zA-Z0-9_.\-=\" ]+$"
    cond str regex="^([a-zA-Z0-9_.\-=! ]+|)$"
    value list str 
}

// Model for dry-out analysis, Per product one will get created
// It will get closed if no open alerts for the product and it was out of dry-out.
Model DryOutHistory {
    bu index_field primary_key str
    sap_id index_field str      // location id
    name index_field str        // Dealer Name
    start_time optional datetime
    end_time optional datetime
    product_no index_field str   //product no
    item_name str                // product name
    plant_id index_field str
    plant_name str
    category optional str          // For category filter
    status index_field AlertStatus // To Check whether Dry-out in Open or Closed

    Config=> {
        crud_operations='read'
        access_key_mapping='bu,sap_id'
    }
}

