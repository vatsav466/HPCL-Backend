Model Alert_History internal {
    device_data optional str
    allocated_time optional str
    processed_time optional str
    mail_sent_to optional str
    action_type AlertActionType
    alert_status optional AlertStatus
    action_msg str
    atr_uploaded optional bool
    maintenance_exception optional bool
    revocation optional bool
    no_exception optional bool
    is_approved optional bool
    is_exc_approval_time_exp optional bool
    is_raised optional bool
    is_cancelled optional bool
    is_allocated optional bool
    is_sent_to_sap optional bool
    is_order_placed optional bool
    is_created optional bool
    is_r1_swipe optional bool
    is_r2_swipe optional bool
    is_r3_swipe optional bool
    is_delivered optional bool
    is_tripped optional bool
}

Model tags internal {
    isAtrUploaded optional bool
    isMaintenanceException optional bool
    isRevocation optional bool
    noException optional bool
    isApproved optional bool
    isExcApprovalTimeExp optional bool
    isRaised optional bool
    isCancelled optional bool
    isAllocated optional bool
    isSentToSap optional bool
    isOrderPlaced optional bool
    isCreated optional bool
    isR1Swipe optional bool
    isR2Swipe optional bool
    isR3Swipe optional bool
    isDelivered optional bool
    isTripped optional bool
}

Model Interlock {
    bu index_field str
    sap_id index_field str
    sop_id index_field str
    interlock_name optional index_field str
    location_name optional str
    device_name optional str
    device_type optional str
    device_id optional str
    state optional index_field str
    city optional index_field str
    zone optional index_field str
    interlock_status optional AlertStatus

    Config=> {
        crud_operations='read'
    }
}

Model EMLock {
    bu index_field str
    sap_id index_field str
    location_name str
    vehicle_number index_field str
    violation_type index_field str
    violation_count int
    violation_start_date datetime
    violation_history optional list str
    status AlertStatus

    Config=> {
        crud_operations='read'
    }
}

Model VTS {
    bu index_field str
    sap_id index_field str
    location_name str
    vehicle_number index_field str
    violation_type index_field str
    violation_count int
    violation_start_date optional datetime
    violation_history optional list str
    block_duration optional str
    block_msg optional str
    status optional AlertStatus
    report_duration optional str
    total_trips optional int

    Config=> {
        crud_operations='read'
    }
}

Model Alerts {
    bu optional index_field BusinessUnit
    sap_id index_field str
    sop_id optional index_field str
    location_name optional str
    severity index_field Severity
    alert_status index_field AlertStatus
    alert_state AlertState                  // Notification or Escalation
    unique_id str                           // System Generated ID Based on <BU>_<INC Number>_<SOP>
    alert_section str                       // For what we are creating alert RO/TAS/VTS/VA/...
    external_id optional str                // AlertId generated by the vendor
    interlock_name optional str
    interlock_id optional str
    device_id optional str
    device_type optional str
    device_name optional str
    device_msg optional str                 // Message received from the device
    vehicle_number optional str
    violation_type optional str
    clear_count optional bool

    // Marking Alert
    is_flagged_false optional bool
    rca optional str
    rca_type optional str


    // Notification Details
    alert_history optional list Alert_History
    last_sms_to optional list str           // List of users to whom sms sent to
    last_mailed_to optional list str        // List of users to whom email sent to
    last_escalated_to optional list str     // List of users to whom alert escalated to
    last_notified_to optional list str      // List of users to whom alert notified to
    assigned_to optional str                // User email for whom alert is assigned to
    assigned_to_role optional str           // User Role for whom alert is assigned to

    // Location Details
    district optional str
    zone optional str
    region optional str
    state optional str
    city optional str
    sales_area optional str

    // Device Raw Details
    raw_data optional dict

    // Dry Out Use Case
    r1_time optional datetime
    r2_time optional datetime
    r3_time optional datetime
    indent_status optional IndentStatus
    product_code optional str
    indent_no optional str
    dealer_id optional str
    workflow_instance_id optional str
    workflow_datetime optional datetime
    terminal_plant_id optional str
    terminal_plant_name optional str
    progress_rate optional int
    category optional str

    Action=> alert_action {
        action_type AlertActionType
        alert_id str
        action_msg optional str
        days optional int
        justificationType optional str
        event_tags optional tags
    }

    Action=> get_performance_index {
        bu str
        skip optional int
        limit optional int
        filters optional list DataFilters
    }

    Action=> upload_image {
    }

    Config=> {
        crud_operations='read'
        search_fields='bu,sap_id,sop_id,location_name,alert_section,interlock_name,device_name,device_id,device_msg,violation_type,rca_type,assigned_to,region,zone,indent_status'
    }
}

