Model Alerts {
    bu optional index_field BusinessUnit
    sap_id index_field str
    sop_id optional index_field str
    location_name optional str
    severity index_field Severity
    alert_category optional str
    alert_status index_field AlertStatus
    alert_state AlertState                  // Notification or Escalation
    unique_id str                           // System Generated ID Based on <BU>_<INC Number>_<SOP>
    alert_section str                       // For what we are creating alert RO/TAS/VTS/VA/...
    external_id optional index_field str     // AlertId generated by the vendor
    interlock_name optional str
    interlock_id optional str
    device_id optional str
    equipment_id optional str
    sensor_id optional str
    device_type optional str
    equipment_type optional str
    device_name optional str
    equipment_name optional str
    tas_device_name optional str
    device_msg optional str                 // Message received from the device
    vehicle_number optional str
    violation_type optional index_field str
    clear_count optional bool
    maintenance_time optional str
    closed_at optional datetime
    cause_effect optional str
    alert_closure_reason optional str

    //tas keys
    tt_load_number optional str

    // Marking Alert
    is_flagged_false optional bool
    rca optional str
    rca_type optional str


    // Notification Details
    alert_history optional list Alert_History
    last_sms_to optional list str           // List of users to whom sms sent to
    last_mailed_to optional list str        // List of users to whom email sent to
    last_escalated_to optional list str     // List of users to whom alert escalated to
    last_notified_to optional list str      // List of users to whom alert notified to
    assigned_to optional str                // User email for whom alert is assigned to
    assigned_to_role optional str           // User Role for whom alert is assigned to
    assigned_users optional list str        // User email for whom alert is assigned to
    assigned_user_roles optional index_field list str   // User Role for whom alert is assigned to

    // Location Details
    district optional str
    zone optional index_field str
    region optional str
    state optional str
    city optional str
    sales_area optional str

    // Device Raw Details
    raw_data optional dict

    // Dry Out Use Case
    r1_time optional datetime
    r2_time optional datetime
    r3_time optional datetime
    indent_status optional index_field IndentStatus
    product_code optional index_field str
    indent_no optional str
    dealer_id optional str
    workflow_instance_id optional str
    workflow_datetime optional datetime
    workflow_url optional str
    workflow_port optional str
    terminal_plant_id optional str
    terminal_plant_name optional str
    // For Indent Rerouting
    servicing_plant_id optional str
    servicing_plant_name optional str
    progress_rate optional index_field int
    category optional str
    indent_raised_date optional datetime
    dry_out_in_days optional index_field str
    origin_altid optional str
    alert_message optional str
    external_timestamp optional datetime_no_zone
    atg_ack optional bool
    emlock_ack optional bool
    vts_return optional bool
    atg_ack_time optional datetime
    dry_out_start_time optional datetime
    dry_out_end_time optional datetime
    intra_day_dry_out_start_time optional datetime
    intra_day_dry_out_end_time optional datetime
    temporary_close optional bool
    permanent_close optional bool
    ro_offline optional bool

    // VTS
    transporter_name optional str
    transporter_code optional str
    vehicle_blocked_start_date optional datetime
    vehicle_blocked_end_date optional datetime
    vehicle_unblocked_date optional datetime
    mark_as_false optional index_field bool
    vts_alert_history_ids optional list str
    action_on optional MakerChecker
    remarks_unblocked optional str
    file_uploaded_path optional str
    block_status optional index_field BlockStatus
    image_uploaded optional bool
    tt_type optional str
    ticket_id optional str
    load_type optional str

    Action=> alert_action {
        bu optional str
        alert_section optional str
        action_type AlertActionType
        alert_id int min=1 max=9999999
        action_msg optional str
        days optional int
        justificationType optional str
        category optional str
        rca_reason optional str
        action_description optional str
        doc_link optional str
        acknowledged_by optional str
        load_number optional str
        fan_number optional str
        invoice_number optional str
        trip_type optional str
        event_tags optional tags
    }
    Action=> intitiate_vts_exception {
        alert_id int min=1 max=9999999
        excep_msg optional str
    }
    Action=> get_performance_index {
        bu str
        skip optional int
        limit optional int
        filters optional list DataFilters
    }

    Action=> add_rca_reason {
        alert_id str
        reason str
    }

    Action=> day_end_closure {
    }

    Action=> upload_document {
    }

    Action=> stored_document {
    }

    Action=> get_frequent_dryout_ro {
        start_date optional datetime
        end_date optional datetime
    }

    Action=> get_frequent_dryout_terminals {
        start_date optional datetime
        end_date optional datetime
    }

    Action=> get_closed_alerts_details {
        bu str
        alert_id int min=1 max=9999999
        alert_section str
        interlock_name str
        category optional str
    }

    Action=> vts_alert_manager {
        filters optional list WidgetFilters
    }

    Action=> bulk_send_to_unblock {
        alert_ids list str
    }

    Action=> bulk_send_to_approve {
        alert_ids list str
    }

    Action=> block_vts_truck {
        bu BusinessUnit
        truck_number str
        blocking_days int
        reason optional str
        remarks optional str
        sap_id optional str
        location_name optional str
        zone optional str
        region optional str
        check_ticket_close optional bool
    }

    Action=> unblock_vts_truck {
        unblock_id str
        remarks str
    }

    Action=> unblock_alert_truck {
        unique_id str
        remarks_unblocked str
    }

    Action=> get_vts_blocked_trucks {
        tab str
        cross_filters optional list WidgetFilters
    }
    
    Action=> get_vts_unblocked_trucks {
        cross_filters optional list WidgetFilters
    }

    Action=> alerts_get_vts_query {
        vehicle_number optional str
        cross_filters optional list WidgetFilters
    }

    Action=> attach_alert_blocked_file {
        unique_id str
        remarks_unblocked str
    }

    Action=> attach_vts_blocked_file {
        unblock_id str
        remarks_unblocked str
    }
    Action=> hqo_blocked_vehicles {
        alert_status str
        start_date optional str
        end_date optional str
    }

    Action=> va_cleanliness_summary {
        cross_filters optional list WidgetFilters
    }

    Action=> download_excel_report {
        // Report model will help for data customization like for VA Cleanlines / TAS MFM / TAS ..
        report_model str
        // For Additional filters
        cross_filters optional list WidgetFilters
    }

    Action=> get_va_cleanliness_last_synced_time {
    }

    Config=> {
        crud_operations='read'
        // Access Key Mapping for RBAC,
        // Example:- 'SBU_NAME:bu,zone,region,sales_area,sap_id'
        // SBU_NAME was the key in database for SBU where as our role will give key as bu
        // If there are no : then we are marking key and value as same
        access_key_mapping='bu,zone,region,sales_area,sap_id,terminal_plant_id:sap_id'
        search_fields='bu,sap_id,sop_id,location_name,alert_section,alert_status,interlock_name,vehicle_number,device_name,device_id,device_msg,device_type,violation_type,rca_type,assigned_to,region,zone,indent_status'
    }
}


