Enum BusinessUnit str {
    RO='RO'
    TAS='TAS'
    LPG='LPG'
    RDI='RDI'
    CP='CP'
    CDCMS='CDCMS'
    ALL='ALL'
}

Enum DeviceType str {
    Tank='Tank'
    DU='DU'
    Pump='Pump'
    Nozzle='Nozzle'
    ATG='ATG'
}

Enum NotificationLevel str {
    InitialNotification='InitialNotification'
    InitialEscalation='InitialEscalation'
}

Enum AlertStatus str {
    Open='Open'
    Close='Close'
    InProgress='InProgress'
    Cancel='Cancel'
    OnHold='OnHold'
}

Enum AlertState str {
    InProgress='InProgress'
    Notified='Notified'
    Escalated='Escalated'
    Resolved='Resolved'
}

Enum Severity str {
    Low='Low'
    Medium='Medium'
    High='High'
    Critical='Critical'
}

Enum LocationHealth str {
    Normal='Normal'
    Failed='Failed'
    Deactivated='Deactivated'
}

Enum AlertActionType str {
    Justification='Justification'
    AcceptClose='AcceptClose'
    FalseAlert='FalseAlert'
    InvalidAlert='InvalidAlert'
    ValidAlert='ValidAlert'
    Rejected='Rejected'
    Approved='Approved'
    Override='Override'
    interLockOk='interLockOk'
    Message='Message'
    excApprovalTimeExp='excApprovalTimeExp'
    Raised='Raised'
    Cancelled='Cancelled'
    Allocated='Allocated'
    SentToSap='SentToSap'
    OrderPlaced='OrderPlaced'
    Created='Created'
    R1Swipe='R1Swipe'
    R2Swipe='R2Swipe'
    R3Swipe='R3Swipe'
    VTS='VTS'
    Delivered='Delivered'
    Tripped='Tripped'
    InterlockCreated='InterlockCreated'
    InterlockCleared='InterlockCleared'
    InterlockNotCleared='InterlockNotCleared'
    UnderMaintenance='UnderMaintenance'
    RevocationApproved='RevocationApproved'
    ExceptionApproved='ExceptionApproved'
    Active='Active'
    Notified='Notified'
    Escalated='Escalated'
    Resolved='Resolved'
    Blocked='Blocked'
    UnBlocked='UnBlocked'
    Request='Request'
    Interrupt='Interrupt'
}

Enum IndentStatus str {
    Pending='Pending'
    IndentNotRaised='IndentNotRaised'
    IndentRaised='IndentRaised'
    IndentOnHold='IndentOnHold'
    IndentOnHoldReleased='IndentOnHoldReleased'
    Cancelled='Cancelled'
    TruckAllocated='TruckAllocated'
    TruckNotAllocated='TruckNotAllocated'
    Transit='Transit'
    InvoiceCreated='InvoiceCreated'
    ValidIndent='ValidIndent'
    SentToSAP='SentToSAP'
    SalesOrderPlaced='SalesOrderPlaced'
    Completed='Completed'
    R1Swipe='R1Swipe'
    R2Swipe='R2Swipe'
    R3Swipe='R3Swipe'
    VTS='VTS'
    Delivered='Delivered'
}

Model RoleMapper internal {
     menu_name str
     allowed_sub_menus optional list str
}

// System role master with allowed pages
Model Roles {
    name index_field unique_field str
    status bool
    allowed_pages optional list RoleMapper

    // API to create system role
    Action=> create_role {
        name str
        allowed_pages optional list RoleMapper
    }

    // API to Enable/Disable system role
    Action=> update_role_status {
        enable bool
        role_name str
    }

    // API to fetch list of pages available for configuring role
    Action=> get_all_pages {

    }

    Config=> {
        crud_operations='read'
    }
}

Model Users {
    // User Information
    username index_field unique_field str
    email index_field str
    first_name str
    last_name str
    password optional secret
    employee_id index_field unique_field str
    employee_number optional str
    // Allocated Role
    // ALL for all
    bu index_field list BusinessUnit
    // ALL for all
    sap_id index_field list str
    system_role index_field list str
    novex_role index_field list str
    region optional list str
    state index_field list str
    zone index_field list str
    sales_area index_field list str
    escalation_level optional NotificationLevel
    // User authentication type
    is_ad_user bool
    status bool
    manual_user bool

    // API to list out created users
    Action=> fetch_users {
        search_string str
        limit optional default=100 int
        skip optional default=0 int
    }

    // API to create user
    Action=> create_user {
        username str
        password str
        first_name str
        last_name str
        employee_id str
        role list str
    }

    // API to Enable/Disable system user
    Action=> update_user_status {
        enable bool
        username str
        first_name str
        last_name str
        region optional list str
        state index_field list str
        zone index_field list str
        sap_id index_field list str
        bu index_field list BusinessUnit
        sales_area index_field list str
        novex_role index_field str
    }

    // API for user login
    Action=> login {
        username str regex="^[a-zA-Z0-9_.-]+$"
        password str
    }

    // API for user logout
    Action=> logout {
    }

    Config=> {
        crud_operations='read'
    }

}

Model DataFilters internal {
    key str
    cond str
    value str
}

Model LocationMaster {
    bu index_field BusinessUnit
    sap_id index_field str
    bu_id optional str
    ro_id optional str
    name index_field str
    is_active optional bool
    activation_date optional datetime
    activation_notes optional str
    activated_by optional str
    deactivated_by optional str
    deactivation_notes optional str
    health_status optional LocationHealth
    health_notes optional str
    scada_vendor optional str
    scada_version optional str
    scada_conn_status optional bool
    scada_conn_notes optional str
    city optional str
    district optional index_field str
    region optional index_field str
    state optional index_field str
    zone optional index_field str
    address optional str
    pincode optional str
    dealer_name optional str
    dealer_phone optional str
    dealer_email optional str
    local_automation_vendor optional str
    latitude optional str
    longitude optional str
    sales_area optional str
    terminal_plant_id optional str
    terminal_plant_name optional str
    category optional str
    distributor_code optional str
    distributor_name optional str
    // For getting what was the round trip time from Plant to Dealer Location and then to Plant
    // This field applicable for Outlets
    round_trip_distance optional int

    Action=> upload_location_master {
    }

    Action=> download_location_master {
    }

    Action=> fetch_global_stats {
        bu optional list BusinessUnit
    }

    Action=> download_template {
    }

    Action=> upload_tags_data {
    }
    
    Action=> update_location_master {
        sap_id index_field str
        name index_field str
        city optional str
        district optional index_field str
        region optional index_field str
        state optional index_field str
        zone optional index_field str
        address optional str
        pincode optional str 
        sales_area optional str
    }

    Action=> get_sod_engineering_stats {
        sap_id str
    }

    Config=> {
        crud_operations='read'
        access_key_mapping='bu,zone,region,sales_area,sap_id'
    }
}

