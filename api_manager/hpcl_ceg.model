    device_working str
    completed_trip	str
    completed_trip_auto_dc str
    card_date datetime_no_zone
    card_time str
    card_datetime datetime_no_zone
    reader_id str
    loaded_on datetime_no_zone
    bu str
    zone str

    Config=> {
        crud_operations='read'
    }

}


Model LpgOperationsInsights {

    Action=> lpg_plants_insights {
        filters optional list WidgetFilters
        cross_filters optional list WidgetFilters
        drill_state optional str
        metric_type str   
    }
}