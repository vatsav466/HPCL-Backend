Model IndentDryOutDataFilters internal {
    key str
    cond str
    value list str
}

Model IndentDryOut {
    bu unique_field index_field primary_key str
    site_id str      // location id
    fcc_code str     // fcc code
    tank_no str      // tank id
    product_no unique_field index_field primary_key str   //product no
    item_name str    // product name
    capacity int     // tank capacity
    volume optional float  // remain volume
    ullage optional float  // empty space in tank
    avgsales_7days optional float // avg sales
    stock_date optional datetime
    status optional int
    daysstatus optional int
    lastrocdate optional datetime
    executed_on optional datetime
    pumpable_stock optional float
    rosapcode unique_field index_field primary_key optional int
    product_grp optional str
    interlock_status optional AlertStatus
    interlock_created_date optional datetime
    interlock_closed_date optional datetime

    Action=> sync_data_from_cris_to_ceg {
        source_connection str
        destination_connection str
        source_table str
        destination_table str
        source_schema optional str
        destination_schema str
        conflict_columns optional list str
    }

    Action=> get_dried_out_plants {
        filters list IndentDryOutDataFilters
    }

    Action=> get_alert_history {
        alert_id str
    }

    Action=> get_dry_out_stats {
        filters list DataFilters
    }

    Action=> get_indent_analysis {
        filters list DataFilters
    }

    Action=> get_distinct_plant {
        bu optional str
        region optional str
    }

    Action=> get_distinct_location_details {
        bu optional str
        zone optional list str
        region optional list str
        sales_area optional list str
    }

    Action=> create_dry_out_alert {

    }

    Action=> sync_ro_daily_sales {
        from_date datetime
        to_date datetime
    }

    Action=> get_dry_out_count {

    }
}

Model Screens {
    screen_title str
    dashboards list int
    created_by optional str
    updated_by optional str
    x optional int
    y optional int
    w optional int
    h optional int
    static optional bool
    moved optional bool
}

// Device Master
Model DeviceMaster {
    bu BusinessUnit
    sap_id str
    ro_id optional str
    device_type DeviceType   // Type of the device pump/nozzle/tank/...
    tank_no optional str     // Number of the tank
    tank_name optional str   // Name of the tank
    tank_capacity optional int // Capacity of tank in liters
    pump_no optional int
    du_no optional int
    nozzle_no optional int
    global_nozzle_no optional int
    product_type str

    Config=> {
        crud_operations='read'
    }
}
