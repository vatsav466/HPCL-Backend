Enum BusinessUnit str {
    RO='RO'
    TAS='TAS'
    LPG='LPG'
    RDI='RDI'
    CP='CP'
}

Enum DeviceType str {
    Tank='Tank'
    DU='DU'
    Pump='Pump'
    Nozzle='Nozzle'
    ATG='ATG'
}

Enum NotificationLevel str {
    InitialNotification='InitialNotification'
    InitialEscalation='InitialEscalation'
}

Enum AlertStatus str {
    Open='Open'
    Close='Close'
    InProgress='InProgress'
    Cancel='Cancel'
    OnHold='OnHold'
}

Enum AlertState str {
    InProgress='InProgress'
    Notified='Notified'
    Escalated='Escalated'
    Resolved='Resolved'
}

Enum Severity str {
    Low='Low'
    Medium='Medium'
    High='High'
    Critical='Critical'
}

Enum LocationHealth str {
    Normal='Normal'
    Failed='Failed'
    Deactivated='Deactivated'
}

Enum AlertActionType str {
    Justification='Justification'
    Rejected='Rejected'
    Approved='Approved'
    Override='Override'
    interLockOk='interLockOk'
    Message='Message'
    excApprovalTimeExp='excApprovalTimeExp'
    Raised='Raised'
    Cancelled='Cancelled'
    Allocated='Allocated'
    SentToSap='SentToSap'
    OrderPlaced='OrderPlaced'
    Created='Created'
    R1Swipe='R1Swipe'
    R2Swipe='R2Swipe'
    R3Swipe='R3Swipe'
    Delivered='Delivered'
    Tripped='Tripped'
    InterlockCleared='InterlockCleared'
    InterlockNotCleared='InterlockNotCleared'
    UnderMaintenance='UnderMaintenance'
    RevocationApproved='RevocationApproved'
    ExceptionApproved='ExceptionApproved'
}

Enum IndentStatus str {
    Pending='Pending'
    IndentNotRaised='IndentNotRaised'
    IndentRaised='IndentRaised'
    IndentOnHold='IndentOnHold'
    IndentOnHoldReleased='IndentOnHoldReleased'
    Cancelled='Cancelled'
    TruckAllocated='TruckAllocated'
    TruckNotAllocated='TruckNotAllocated'
    Transit='Transit'
    InvoiceCreated='InvoiceCreated'
    ValidIndent='ValidIndent'
    SentToSAP='SentToSAP'
    SalesOrderPlaced='SalesOrderPlaced'
    Completed='Completed'
    R1Swipe='R1Swipe'
    R2Swipe='R2Swipe'
    R3Swipe='R3Swipe'
    Delivered='Delivered'
}

Model DataFilters internal {
    key str
    cond str
    value str
}

Model LocationMaster {
    bu index_field BusinessUnit
    sap_id index_field str
    bu_id optional str
    ro_id optional str
    name index_field str
    is_active optional bool
    activation_date optional datetime
    activation_notes optional str
    activated_by optional str
    deactivated_by optional str
    deactivation_notes optional str
    health_status optional LocationHealth
    health_notes optional str
    scada_vendor optional str
    scada_version optional str
    scada_conn_status optional bool
    scada_conn_notes optional str
    city optional str
    district optional index_field str
    region optional index_field str
    state optional index_field str
    zone optional index_field str
    address optional str
    pincode optional str
    dealer_name optional str
    dealer_phone optional str
    dealer_email optional str
    local_automation_vendor optional str
    latitude optional str
    longitude optional str
    sales_area optional str
    terminal_plant_id optional str
    terminal_plant_name optional str
    category optional str

    Action=> upload_location_master {
    }

    Action=> download_location_master {
    }

    Action=> fetch_global_stats {
        bu optional list BusinessUnit
    }

    Action=> download_template {
    }

    Config=> {
        crud_operations='read'
    }
}

Model RoleMaster {
    bu index_field BusinessUnit
    sap_id index_field str
    location_name str
    user_name optional str
    role index_field str
    email str
    phone_no str
    city index_field str
    district optional str
    region optional str
    state index_field str
    zone index_field str
    escalation_level optional NotificationLevel

    Action=> upload_role_master {
    }

    Action=> download_role_master {
    }

    Action=> download_template {
    }

    Config=> {
        crud_operations='read'
    }
}

