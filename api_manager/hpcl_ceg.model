    tank_id int
    nozzle_id int
    global_nozzle_id int
    region optional str
    state optional str
    city optional str

    Action=> upload_ro_asset_master{
    }

    Action=> download_ro_asset_master{
    }

    Action=> download_template {
    }

    Config=> {
        crud_operations='read'
    }
}

