{
    "database": "4",
    "schema": "public",
    "table": "aws_resource_clearpier_cost",
    "visualization_name": "pie",
    "name": "Top 5 Billed Regions in the last month",
    "description": "",
    "params": {
      "queries": [
        {
          "filters": [
            {
              "col": "start",
              "op": "TEMPORAL_RANGE",
              "val": "2024-06-01T00:00:00 : 2024-07-01T00:00:00"
            },
            {
              "col": "region",
              "op": "NOT IN",
              "val": ["NoRegion"]
            }
          ],
          "columns": [],
          "metrics": [
            {
              "expression_type": "SIMPLE",
              "column": {
                "column_name": "amount",
                "type": "FLOAT"
              },
              "aggregate": "SUM",
              "label": "Amount"
            }
          ],
          "orderby": [
            {
              "order_by": false,
              "expression_type": "SIMPLE",
              "column": {
                "column_name": "amount",
                "type": "FLOAT"
              },
              "aggregate": "SUM",
              "label": "Amount"
            }
          ],
          "row_limit": 5,
          "series_columns": [],
          "series_limit": 0,
          "order_descending": true
        }
      ],
      "form_data": {
        "x_axis": {},
        "metrics": [],
        "groupby": [
          {
            "name":"region_name",
            "label":"Region Name"
          }
        ],
        "order_descending": false,
        "row_limit": 0,
        "show_legend": false
      }
    }
  }
